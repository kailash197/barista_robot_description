<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:property name="radius" value="0.010"/>
    <xacro:property name="width" value="0.220"/>
    <xacro:property name="mass" value="0.1000"/>
    <!-- Calculated inertial properties -->
    <xacro:property name="ixx" value="${(1/12.0) * mass * (3 * pow(radius, 2) + pow(width, 2))}"/>
    <xacro:property name="iyy" value="${(1/12.0) * mass * (3 * pow(radius, 2) + pow(width, 2))}"/>
    <xacro:property name="izz" value="${0.5 * mass * pow(radius, 2)}"/>

    <xacro:macro name="standoff_rods" params="name color">
        <link name="${name}">
            <visual>
                <geometry>
                    <cylinder radius="${radius}" length="${width}"/>
                </geometry>
                <material name="${color}"/>
            </visual>
            <collision>
                <geometry>
                    <cylinder radius="${radius}" length="${width}"/>
                </geometry>
            </collision>
            <inertial>
                <mass value="${mass}"/>
                <origin rpy="0 0 0" xyz="0 0 0"/>
                <inertia ixx="${ixx}" iyy="${iyy}" izz="${izz}" ixy="0" iyz="0" ixz="0"/>
            </inertial>
        </link>
        <gazebo reference="${name}">
            <material>Gazebo/${color}</material>
        </gazebo>
    </xacro:macro>
</robot>