<?xml version="1.0"?>
<robot name="barista_bot">
    <link name="base_link"/>

    <joint name="base_link_joint" type="fixed">
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <parent link="base_link"/>
        <child link="base_plate_link"/>
    </joint>
    
    <link name="base_plate_link">
        <visual>
            <geometry>
                <cylinder length="0.155" radius="0.178"/>
            </geometry>
        </visual>
        <collision>
            <geometry>
                <cylinder length="0.155" radius="0.178"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.5"/>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <inertia ixx="0.0008333333333333335" ixy="0" ixz="0" iyy="0.0008333333333333335" iyz="0" izz="0.0008333333333333335"/>
        </inertial>
    </link>

    <joint name="standoff_rods1_joint" type="fixed">
