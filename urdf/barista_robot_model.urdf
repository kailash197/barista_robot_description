<?xml version="1.0"?>
<robot name="barista_bot">
    <material name="red">
        <color rgba="1.0 0.0 0.0 1"/>
    </material>
    <material name="green_dark">
        <color rgba="0.0 0.5 0.0 1"/>
    </material>
    <material name="blue">
        <color rgba="0.0 0.0 1.0 1"/>
    </material>

    <link name="base_link"/>

    <joint name="base_link_joint" type="fixed">
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <parent link="base_link"/>
        <child link="base_plate_link"/>
    </joint>
    
    <link name="base_plate_link">
        <visual>
            <geometry>
                <cylinder length="0.155" radius="0.178"/>
            </geometry>
        </visual>
        <collision>
            <geometry>
                <cylinder length="0.155" radius="0.178"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.5"/>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <inertia ixx="0.0008333333333333335" ixy="0" ixz="0" iyy="0.0008333333333333335" iyz="0" izz="0.0008333333333333335"/>
        </inertial>
    </link>

    <!-- Wheel Left -->
    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_plate_link"/>
        <child link="left_wheel_link"/>
        <origin xyz="0.0 0.15 -0.0528" rpy="-1.57 0 0"/>
        <axis rpy="0 0 0" xyz="0 0 1"/>
        <limit effort="10000" velocity="1000"/>
        <joint_properties damping="1.0" friction="1.0"/>        
    </joint>

    <link name="left_wheel_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.0206" radius="0.0352"/>
            </geometry>
            <material name="blue"/>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.0206" radius="0.0352"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0 0 0" />
            <mass value="2.8498940e-02" />
            <inertia ixx="1.1175580e-05" ixy="-4.2369783e-11" ixz="-5.9381719e-09" iyy="1.1192413e-05" iyz="-1.4400107e-11" izz="2.0712558e-05" />
        </inertial>
    </link>

    <!-- Wheel Right -->
    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_plate_link"/>
        <child link="right_wheel_link"/>
        <origin xyz="0.0 -0.15 -0.0528" rpy="-1.57 0 0"/>
        <axis rpy="0 0 0" xyz="0 0 1"/>
        <limit effort="10000" velocity="1000"/>
        <joint_properties damping="1.0" friction="1.0"/>        
    </joint>

    <link name="right_wheel_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.0206" radius="0.0352"/>
            </geometry>
            <material name="blue"/>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.0206" radius="0.0352"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0 0 0" />
            <mass value="2.8498940e-02" />
            <inertia ixx="1.1175580e-05" ixy="-4.2369783e-11" ixz="-5.9381719e-09" iyy="1.1192413e-05" iyz="-1.4400107e-11" izz="2.0712558e-05" />
        </inertial>
    </link>

    <!-- Caster Wheel Front -->
    <link name="front_yaw_link">
        <visual>
            <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
            <geometry>
                <cylinder length="0.005" radius="0.0150"/>
            </geometry>
            <material name="blue"/>
        </visual>
    </link>

    <joint name="front_yaw_joint" type="continuous">
        <origin rpy="0 0 0" xyz="0.150 0 -0.0730" />
        <parent link="base_plate_link" />
        <child link="front_yaw_link" />
        <axis xyz="0 0 1" />
        <limit effort="1000.0" velocity="100.0" />
        <dynamics damping="0.0" friction="0.1"/>
    </joint>

    <link name="front_roll_link">
        <visual>
            <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
            <geometry>
                <cylinder length="0.005" radius="0.0150"/>
            </geometry>
            <material name="red"/>
        </visual>
    </link>

    <joint name="front_roll_joint" type="continuous">
        <origin rpy="0 0 0" xyz="0 0 0" />
        <parent link="front_yaw_link" />
        <child link="front_roll_link" />
        <axis xyz="1 0 0" />
        <limit effort="1000.0" velocity="100.0" />
        <dynamics damping="0.0" friction="0.1"/>
    </joint>

    <link name="front_pitch_link">
        <visual>
            <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
            <geometry>
                <sphere radius="0.0150"/>
            </geometry>
            <material name="green_dark"/>
        </visual>
    </link>

    <joint name="front_pitch_joint" type="continuous">
        <origin rpy="0 0 0" xyz="0 0 0" />
        <parent link="front_roll_link" />
        <child link="front_pitch_link" />
        <axis xyz="0 1 0" />
        <limit effort="1000.0" velocity="100.0" />
        <dynamics damping="0.0" friction="0.1"/>
    </joint>

    <!-- Caster Wheel Back -->
    <link name="back_yaw_link">
        <visual>
            <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
            <geometry>
                <cylinder length="0.005" radius="0.0150"/>
            </geometry>
            <material name="blue"/>
        </visual>
    </link>

    <joint name="back_yaw_joint" type="continuous">
        <origin rpy="0 0 0" xyz="-0.150 0 -0.0730" />
        <parent link="base_plate_link" />
        <child link="back_yaw_link" />
        <axis xyz="0 0 1" />
        <limit effort="1000.0" velocity="100.0" />
        <dynamics damping="0.0" friction="0.1"/>
    </joint>

    <link name="back_roll_link">
        <visual>
            <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
            <geometry>
                <cylinder length="0.005" radius="0.0150"/>
            </geometry>
            <material name="red"/>
        </visual>
    </link>

    <joint name="back_roll_joint" type="continuous">
        <origin rpy="0 0 0" xyz="0 0 0" />
        <parent link="back_yaw_link" />
        <child link="back_roll_link" />
        <axis xyz="1 0 0" />
        <limit effort="1000.0" velocity="100.0" />
        <dynamics damping="0.0" friction="0.1"/>
    </joint>

    <link name="back_pitch_link">
        <visual>
            <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
            <geometry>
                <sphere radius="0.0150"/>
            </geometry>
            <material name="green_dark"/>
        </visual>
    </link>

    <joint name="back_pitch_joint" type="continuous">
        <origin rpy="0 0 0" xyz="0 0 0" />
        <parent link="back_roll_link" />
        <child link="back_pitch_link" />
        <axis xyz="0 1 0" />
        <limit effort="1000.0" velocity="100.0" />
        <dynamics damping="0.0" friction="0.1"/>
    </joint>

    <!-- Standoff rods -->
    <joint name="standoff_rods1_joint" type="fixed">
        <origin rpy="0 0 0" xyz="0.03 0.13 0.1875"/>
        <parent link="base_plate_link"/>
        <child link="standoff_rods1_link"/>
    </joint>
    
    <link name="standoff_rods1_link">
        <visual>
            <geometry>
                <cylinder length="0.220" radius="0.010"/>
            </geometry>
        </visual>
        <collision>
            <geometry>
                <cylinder length="0.220" radius="0.010"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <inertia ixx="0.0008333333333333335" ixy="0" ixz="0" iyy="0.0008333333333333335" iyz="0" izz="0.0008333333333333335"/>
        </inertial>
    </link>

    <joint name="cup_holder_tray_joint" type="fixed">
        <origin rpy="0 0 0" xyz="0 0 0.3425"/>
        <parent link="base_plate_link"/>
        <child link="cup_holder_tray_link"/>
    </joint>
    
    <link name="cup_holder_tray_link">
        <visual>
            <geometry>
                <cylinder length="0.090" radius="0.160"/>
            </geometry>
        </visual>
        <collision>
            <geometry>
                <cylinder length="0.090" radius="0.160"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.4"/>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <inertia ixx="0.0008333333333333335" ixy="0" ixz="0" iyy="0.0008333333333333335" iyz="0" izz="0.0008333333333333335"/>
        </inertial>
    </link>

    <joint name="standoff_rods2_joint" type="fixed">
        <origin rpy="0 0 0" xyz="-0.03 0.13 0.1875"/>
        <parent link="base_plate_link"/>
        <child link="standoff_rods2_link"/>
    </joint>
    
    <link name="standoff_rods2_link">
        <visual>
            <geometry>
                <cylinder length="0.220" radius="0.010"/>
            </geometry>
        </visual>
        <collision>
            <geometry>
                <cylinder length="0.220" radius="0.010"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <inertia ixx="0.0008333333333333335" ixy="0" ixz="0" iyy="0.0008333333333333335" iyz="0" izz="0.0008333333333333335"/>
        </inertial>
    </link>

    <joint name="standoff_rods3_joint" type="fixed">
        <origin rpy="0 0 0" xyz="-0.03 -0.13 0.1875"/>
        <parent link="base_plate_link"/>
        <child link="standoff_rods3_link"/>
    </joint>
    
    <link name="standoff_rods3_link">
        <visual>
            <geometry>
                <cylinder length="0.220" radius="0.010"/>
            </geometry>
        </visual>
        <collision>
            <geometry>
                <cylinder length="0.220" radius="0.010"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <inertia ixx="0.0008333333333333335" ixy="0" ixz="0" iyy="0.0008333333333333335" iyz="0" izz="0.0008333333333333335"/>
        </inertial>
    </link>

    <joint name="standoff_rods4_joint" type="fixed">
        <origin rpy="0 0 0" xyz="0.03 -0.13 0.1875"/>
        <parent link="base_plate_link"/>
        <child link="standoff_rods4_link"/>
    </joint>
    
    <link name="standoff_rods4_link">
        <visual>
            <geometry>
                <cylinder length="0.220" radius="0.010"/>
            </geometry>
        </visual>
        <collision>
            <geometry>
                <cylinder length="0.220" radius="0.010"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <inertia ixx="0.0008333333333333335" ixy="0" ixz="0" iyy="0.0008333333333333335" iyz="0" izz="0.0008333333333333335"/>
        </inertial>
    </link>

    <link name="laser_scan_frame"/>

    <joint name="laser_scan_frame_joint" type="fixed">
        <origin rpy="0 0 0" xyz="0.10 0.0 0.09125"/>
        <parent link="base_plate_link"/>
        <child link="laser_scan_frame"/>
        <axis xyz="0 0 0"/>
    </joint>

    <!-- Visual Laser Model to be rotated -->
    <joint name="laser_scanner_joint" type="continuous">
        <origin rpy="0 0 0" xyz="0.10 0.0 0.09125"/>
        <parent link="base_plate_link"/>
        <child link="laser_scanner_link"/>
        <axis xyz="0 0 1"/>
        <limit effort="10.0" velocity="2.0"/>
        <dynamics friction="0.01"/>
    </joint>
    
    <link name="laser_scanner_link">
        <visual>
            <geometry>
                <!-- <cylinder length="0.0275" radius="0.030"/> -->
                <mesh filename="package://barista_robot_description/meshes/hokuyo_urg_04lx.dae" scale="1.0 1.0 1.0"/>
            </geometry>
        </visual>
        <collision>
            <geometry>
                <cylinder length="0.0275" radius="0.030"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <inertia ixx="0.0008333333333333335" ixy="0" ixz="0" iyy="0.0008333333333333335" iyz="0" izz="0.0008333333333333335"/>
        </inertial>
    </link>
    <!-- Position Config -->
    <ros2_control name="GazeboSystem" type="system">
        <hardware>
            <plugin>gazebo_ros2_control/GazeboSystem</plugin>
        </hardware>
        <joint name="laser_scanner_joint">
            <command_interface name="velocity">
                <param name="min">0.0</param>
                <param name="max">2.0</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
    </ros2_control>
    <gazebo>
        <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
            <parameters>$(find barista_robot_description)/config/controller_position.yaml</parameters>
            <robot_param_node>/barista_bot_state_publisher_node</robot_param_node>
        </plugin>
    </gazebo>
    <gazebo reference="laser_scan_frame">
        <sensor name="sensor_ray" type="ray">
            <pose>0 0 0 0 0 0</pose>
            <ray>
                <scan>
                <horizontal>
                    <samples>200</samples>
                    <resolution>1.0</resolution>
                    <min_angle>-3.14</min_angle>
                    <max_angle>3.14</max_angle>
                </horizontal>
                </scan>
                <range>
                <min>0.1</min>
                <max>5.0</max>
                </range>
            </ray>
            <always_on>true</always_on>
            <visualize>true</visualize>
            <update_rate>100.0</update_rate>
            <plugin name="laser" filename="libgazebo_ros_ray_sensor.so">
                <ros>
                <namespace>/box_bot</namespace>
                <remapping>~/out:=laser_scan</remapping>
                </ros>
                <output_type>sensor_msgs/LaserScan</output_type>
            </plugin>
        </sensor>
    </gazebo>
    
    <!-- Differential drive -->
    <gazebo>
        <plugin filename="libgazebo_ros_diff_drive.so" name="differential_drive_controller">

        <!-- wheels -->
        <left_joint>left_wheel_joint</left_joint>
        <right_joint>right_wheel_joint</right_joint>

        <!-- kinematics -->
        <wheel_separation>0.300</wheel_separation>
        <wheel_diameter>0.0704</wheel_diameter>

        <!-- limits -->
        <max_wheel_torque>1.0</max_wheel_torque>
        <max_wheel_acceleration>2.0</max_wheel_acceleration>

        <!-- output -->
        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>

        <odometry_frame>odom</odometry_frame>
        <robot_base_frame>base_link</robot_base_frame>

        </plugin>
    </gazebo>
</robot>
